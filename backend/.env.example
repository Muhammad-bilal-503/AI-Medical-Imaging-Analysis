# Supabase — copy the exact values shown in your project's
# "Connect to your project" panel (Server tab). Do not add any path
# after SUPABASE_URL (no /.well-known/... etc).
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...
SUPABASE_JWKS_URL=https://YOUR_PROJECT_REF.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_LEGACY_SERVICE_ROLE_JWT=eyJ...
# ^ Project Settings > API > Legacy API Keys > service_role. Used ONLY
# for admin account creation (Auth Admin API). Treat this like the old
# service_role key — never expose it to the frontend.

# App
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
RATE_LIMIT_PER_MINUTE=60

# Storage buckets (create these in Supabase Storage)
BUCKET_MEDICAL_IMAGES=medical-images
BUCKET_HEATMAPS=heatmaps
BUCKET_REPORTS=reports

# LLM (later phase)
GROQ_API_KEY=
